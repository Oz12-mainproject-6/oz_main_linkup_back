# ===========================================
# Environment Configuration Template
# Copy this file to .env and fill in the values
# ===========================================

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# PostgreSQL container settings
POSTGRES_DB=oz_linkup
POSTGRES_USER=postgres  
POSTGRES_PASSWORD=password

# Application database settings
DB_HOST=localhost  # Use 'db' for docker deployment
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=oz_linkup

# ===========================================
# APPLICATION SETTINGS
# ===========================================
ENVIRONMENT=development  # development | production

# Database URL - CHOOSE ONE:
# For LOCAL development:
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/oz_linkup
# For DOCKER deployment (uncomment above line and use this):
# DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/oz_linkup

# Dummy data creation (development only)
CREATE_DUMMY_DATA=false  # true | false

# ===========================================
# JWT AUTHENTICATION
# ===========================================
JWT_SECRET_KEY=your-super-secret-jwt-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===========================================
# OAUTH CONFIGURATION (Optional)
# ===========================================
# Google OAuth (for social login)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Kakao OAuth (for social login)
KAKAO_CLIENT_ID=your-kakao-client-id
KAKAO_CLIENT_SECRET=your-kakao-client-secret

# Frontend URL (for OAuth redirects)
FRONTEND_URL=http://localhost:3000

# ===========================================
# EMAIL CONFIGURATION (Optional)
# ===========================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@linkup.com

# ===========================================
# AWS S3 CONFIGURATION (Optional)
# ===========================================
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=your-s3-bucket-name

# ===========================================
# QUICK SETUP GUIDE
# ===========================================
# 1. LOCAL DEVELOPMENT:
#    - Keep DATABASE_URL with localhost
#    - Set CREATE_DUMMY_DATA=true for test data
#    - Run: docker-compose up db -d
#    - Run: uv run uvicorn app.main:app --reload
#
# 2. DOCKER DEPLOYMENT:
#    - Change DATABASE_URL to use @db:5432
#    - Run: docker-compose up --build
#
# 3. PRODUCTION:
#    - Set ENVIRONMENT=production
#    - Use strong JWT_SECRET_KEY (32+ chars)
#    - Set CREATE_DUMMY_DATA=false
#    - Configure real OAuth/AWS credentials
# Database configuration for PostgreSQL container
POSTGRES_DB=linkup
POSTGRES_USER=linkup
POSTGRES_PASSWORD=linkup

# Database configuration for application
DB_HOST=localhost
DB_PORT=5432
DB_USER=linkup
DB_PASSWORD=linkup
DB_NAME=linkup

# Application configuration
ENVIRONMENT=development
DATABASE_URL=postgresql+asyncpg://linkup:linkup@localhost:5432/linkup
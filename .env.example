# ===========================================
# OZ LinkUp Backend - Environment Variables
# ===========================================

# Application Environment
# development: 개발 환경 (이메일 코드 로그 출력, 쿠키 토큰 저장)
# production: 프로덕션 환경 (실제 이메일 전송)
ENVIRONMENT=development

# Frontend URL
# 프론트엔드 도메인 설정 (OAuth 콜백 리다이렉트용)
# 개발: http://localhost:3000
# 배포: https://dev.linkup.n-e.kr
FRONTEND_URL=https://dev.linkup.n-e.kr

# ===========================================
# Database Configuration
# ===========================================
DB_HOST=db
DB_PORT=5432
DB_USER=linkup
DB_PASSWORD=linkup
DB_NAME=linkup

# ===========================================
# JWT Authentication
# ===========================================
# 프로덕션에서는 반드시 강력한 시크릿 키로 변경 필요!
# python -c "import secrets; print(secrets.token_urlsafe(32))" 로 생성 가능
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
# 토큰 만료 시간 (분 단위, 기본: 7일 = 10080분)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ===========================================
# Email Service (SMTP)
# ===========================================
# Gmail 사용 시 앱 비밀번호 생성 필요
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@linkup.com

# ===========================================
# OAuth Social Login
# ===========================================

# Google OAuth 2.0
# Google Cloud Console에서 생성: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Kakao OAuth 2.0  
# Kakao Developers에서 생성: https://developers.kakao.com/
KAKAO_CLIENT_ID=your-kakao-client-id
KAKAO_CLIENT_SECRET=your-kakao-client-secret

# ===========================================
# AWS S3 Configuration
# ===========================================
# 이미지 업로드용 S3 설정
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=your-s3-bucket-name

# ===========================================
# Docker Environment (docker-compose.yml용)
# ===========================================
# PostgreSQL Docker 컨테이너 설정
POSTGRES_DB=oz_linkup
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password